extends layout

block content
  - var dataset_count = pkgdata.reduce((n, p) => n + (Array.isArray(p._datasets) ? p._datasets.length : 0), 0)
  .position-relative.mt-3.mb-1#dataset-toolbar
    i.fas.fa-filter.position-absolute.text-muted.small(style='left:12px; top:50%; transform:translateY(-50%); pointer-events:none;')
    input#dataset-filter.form-control.ps-5(type='search' placeholder=`Filter ${dataset_count} datasets by name, title or class…` autocomplete='off' spellcheck='false')
  small#dataset-count.text-muted.d-none.d-block.mb-1
  #dataset-noresults.text-muted.text-center.py-5.d-none
    i.fas.fa-table.fa-2x.mb-3.d-block.text-secondary
    | No datasets match
    span#dataset-noresults-term.fw-bold
  ol.list-group.list-group-numbered.mt-4#dataset-list
    each pkg in pkgdata
      if pkg._datasets
        - var prefix = pkg._user == universe ? "" : `https://${pkg._user}.r-universe.dev`
        each x in pkg._datasets
          li.list-group-item.list-group-item-action.d-flex.justify-content-between.align-items-start.dataset-item(
            data-name=`${pkg.Package}::${x.name}`
            data-title=(x.title || '')
            data-class=(Array.isArray(x.class) ? x.class.join(' ') : (x.class || ''))
          )
            .ms-2.me-auto
              .fw-bold #{pkg.Package}::#{x.name}
              i #{x.title}
            .align-middle.text-end
              .text-nowrap
                if x.table
                  a(target='_blank' type='button' href=`${prefix}/${pkg.Package}/data/${x.name}/csv`)
                    |  csv
                    span.mx-1 |
                if x.table && Array.isArray(x.class) && x.class.includes('data.frame')
                  a(target='_blank' type='button' href=`${prefix}/${pkg.Package}/data/${x.name}/xlsx`)
                    |  xlsx
                    span.mx-1 |
                if x.tojson
                  a(target='_blank' type='button' href=`${prefix}/${pkg.Package}/data/${x.name}/json`)
                    |  json
                    span.mx-1 |
                if x.tojson && Array.isArray(x.class) && x.class.includes('data.frame')
                  a(target='_blank' type='button' href=`${prefix}/${pkg.Package}/data/${x.name}/ndjson`)
                    |  ndjson
                    span.mx-1 |
                a(target='_blank' type='button' href=`${prefix}/${pkg.Package}/data/${x.name}/rda`)
                  |  rda
                  span.mx-1 |
                a(target='_blank' type='button' href=`${prefix}/${pkg.Package}/data/${x.name}/rds`)
                  |  rds
              .text-secondary.text-end.small #{x.class[0]}
                if x.rows
                  span.mx-1 |
                  | #{x.rows} x #{x.fields.length}

block after_scripts
  script
    include datasets.js
